@model List<CustomerServicesSystem.ViewModels.UserListItemVM>
@{ ViewData["Title"] = "User Management"; }

<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <h5 class="mb-0 fw-bold"><i class="fas fa-users-cog me-2 text-primary"></i>User Management</h5>
        <small class="text-muted">Manage system users and their roles</small>
    </div>
    <a asp-action="Create" class="btn btn-primary btn-sm">
        <i class="fas fa-user-plus me-1"></i> Add User
    </a>
</div>

<div class="card">
    <div class="card-header-blue d-flex align-items-center gap-2">
        <i class="fas fa-list"></i>
        <span class="fw-semibold">All Users (@Model.Count)</span>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Full Name</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Status</th>
                        <th>Created</th>
                        <th style="width:160px">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 0; i < Model.Count; i++)
                    {
                        var u = Model[i];
                        <tr>
                            <td class="text-muted">@(i + 1)</td>
                            <td class="fw-semibold">@u.FullName</td>
                            <td>@u.Email</td>
                            <td>
                                @{
                                    var (badgeClass, icon) = u.Role switch
                                    {
                                        "Admin"      => ("bg-danger",  "fas fa-shield-halved"),
                                        "Supervisor" => ("bg-warning text-dark", "fas fa-user-tie"),
                                        _            => ("bg-secondary", "fas fa-user")
                                    };
                                }
                                <span class="badge @badgeClass">
                                    <i class="@icon me-1"></i>@u.Role
                                </span>
                            </td>
                            <td>
                                @if (u.IsActive)
                                {
                                    <span class="badge bg-success"><i class="fas fa-circle me-1" style="font-size:8px"></i>Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary"><i class="fas fa-circle me-1" style="font-size:8px"></i>Inactive</span>
                                }
                            </td>
                            <td class="text-muted" style="font-size:12px">@u.CreatedAt.ToString("yyyy-MM-dd")</td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@u.Id"
                                   class="btn btn-sm btn-outline-primary me-1" title="Edit">
                                    <i class="fas fa-pen"></i>
                                </a>

                                <form asp-action="ToggleActive" asp-route-id="@u.Id"
                                      method="post" class="d-inline"
                                      onsubmit="return confirm('Toggle active status for this user?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit"
                                            class="btn btn-sm @(u.IsActive ? "btn-outline-warning" : "btn-outline-success") me-1"
                                            title="@(u.IsActive ? "Deactivate" : "Activate")">
                                        <i class="fas @(u.IsActive ? "fa-ban" : "fa-check")"></i>
                                    </button>
                                </form>

                                <form asp-action="Delete" asp-route-id="@u.Id"
                                      method="post" class="d-inline"
                                      onsubmit="return confirm('Delete user @u.FullName? This cannot be undone.')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr><td colspan="7" class="text-center text-muted py-4">No users found.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
